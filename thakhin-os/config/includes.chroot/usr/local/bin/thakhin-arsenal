#!/bin/bash
# thakhin-arsenal — show which offensive/defensive tools are loaded in this
# Thakhin OS install (Kali/Parrot-style arsenal, curated by AnonyLatt ဌာနကြီး).
GOLD='\033[1;33m'; GREEN='\033[1;32m'; DIM='\033[0;90m'; NC='\033[0m'

declare -A CAT=(
  ["🔎 Recon / Scanning"]="nmap masscan arp-scan hping3 dnsrecon dnsenum fierce theharvester recon-ng dmitry"
  ["🕵️ Sniff / MITM"]="wireshark tshark tcpdump ettercap bettercap mitmproxy responder macchanger"
  ["📶 Wireless"]="aircrack-ng reaver wifite kismet pixiewps hcxdumptool mdk4"
  ["🔑 Passwords"]="john hashcat hydra medusa ncrack crunch cewl hashid"
  ["🌐 Web"]="sqlmap nikto dirb gobuster ffuf wfuzz whatweb wpscan nuclei zaproxy"
  ["💥 Exploitation"]="msfconsole msfvenom setoolkit searchsploit crackmapexec netexec impacket-getnthash"
  ["🧬 Reverse / Forensics"]="radare2 rizin gdb ltrace strace binwalk foremost exiftool steghide yara volatility3"
  ["🛡️ Audit / Anon"]="lynis chkrootkit rkhunter tor proxychains4 openvpn sshuttle"
)

echo -e "${GOLD}☸ ═══ Thakhin OS — တောသားနှိမ်နင်းရေး Security Arsenal ═══ ☸${NC}"
echo -e "${DIM}   ဥက္ကဋ္ဌကြီး ဝင်းကိုကိုလတ် (AnonyLatt) မှ ကြီးကြပ်၍ တပ်ဆင်ထားသည်${NC}\n"

order=("🔎 Recon / Scanning" "🕵️ Sniff / MITM" "📶 Wireless" "🔑 Passwords" "🌐 Web" "💥 Exploitation" "🧬 Reverse / Forensics" "🛡️ Audit / Anon")
total=0; have=0
for cat in "${order[@]}"; do
  echo -e "${GOLD}${cat}${NC}"
  line="   "
  for t in ${CAT[$cat]}; do
    total=$((total+1))
    if command -v "$t" >/dev/null 2>&1; then
      line+="${GREEN}✔ $t${NC}  "; have=$((have+1))
    else
      line+="${DIM}✗ $t${NC}  "
    fi
  done
  echo -e "$line\n"
done
echo -e "${GOLD}ရရှိပြီး: ${GREEN}$have${GOLD} / $total tools${NC}   ${DIM}(✔ = ready, dimmed = not installed)${NC}"
echo -e "${DIM}   'thakhin apt install <tool>' ဖြင့် ထပ်ဖြည့်နိုင်သည် — Kali repo ချိတ်ပြီးသား။${NC}"
