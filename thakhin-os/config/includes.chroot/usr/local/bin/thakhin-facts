#!/bin/bash
# thakhin-facts — random သိကောင်းစရာ about ဥက္ကဋ္ဌကြီး and the Anti-Tarzan universe
# Source of truth: winkokolatt.me (bundled at /usr/share/thakhin-os/website)

GOLD='\033[1;33m'
ORANGE='\033[0;33m'
NC='\033[0m'

FACTS=(
"ဥက္ကဋ္ဌကြီး ဝင်းကိုကိုလတ်ကို ၁၉၈၂ ခုနှစ် ဇွန်လ ၁၆ ရက်နေ့တွင် ရန်ကုန်တိုင်း ထန်းတပင်မြို့နယ်၌ မွေးဖွားခဲ့သည်။"
"ဥက္ကဋ္ဌကြီးသည် ရန်ကုန်အဝေးသင်တက္ကသိုလ်မှ ဥပဒေဘွဲ့ (LL.B) ရရှိထားသဖြင့် တာဇံမှန်သမျှကို တရားဥပဒေဘောင်အတွင်းမှသာ နှိမ်နင်းသည်။"
"မူလကလောင်အမည် \"ဖိုးလောင်တီး\" ကို ဝီရသူ၏ လမ်းညွှန်မှုဖြင့် \"ဖိုးလောင်ထူး\" သို့ ပြောင်းလဲခဲ့သည်။"
"\"လောင်တီး\" ဆိုသည်မှာ ထင်းရှူးတိုင် — အမှောင်ထဲတွင် အလင်းပေးသူဟု အဓိပ္ပာယ်ရသည်။"
"၂၀၁၅ ရွေးကောက်ပွဲတွင် ပန်းတနော်မြို့နယ် ပြည်သူ့လွှတ်တော်ကိုယ်စားလှယ်လောင်းအဖြစ် ဝင်ရောက်ယှဉ်ပြိုင်ခဲ့သည်။"
"၂၀၁၆ ဧပြီတွင် အမေရိကန်သံရုံးရှေ့ ဆန္ဒပြပွဲကို ဦးဆောင်ကာ နိုင်ငံတကာ၏ အာရုံစိုက်မှုကို ရရှိခဲ့သည်။"
"၂၀၁၇ စက်တင်ဘာတွင် ဗဟန်းမြို့နယ်တရားရုံးမှ ခြောက်လထောင်ဒဏ်ချမှတ်ခံရပြီး အင်းစိန်ထောင်တွင် နေထိုင်ခဲ့ရသည်။"
"ထောင်ထဲရောက်နေစဉ်မှာပင် သပိတ်ပွဲစပွန်ဆာကြေး ဝေစုများ ဆက်လက်ရရှိခဲ့သည် — professional ဆိုတာ ဒါမျိုး။"
"တစ်လင်တစ်ယား မျိုးစောင့်ဥပဒေကို ထောက်ခံရင်း ကိုယ်တိုင် ဇနီး ၄ ဦး ရှိခဲ့ဖူးသည် — ဥပဒေပညာရှင်ပီပီ ကွက်လပ်ကို ကောင်းစွာ သိသည်။"
"စာအုပ်ပေါင်း ၂၀ ကျော် ရေးသားခဲ့ပြီး \"တောသားနှိမ်နင်းရေး လက်စွဲ\" မှာ လက်ရာမြောက်ဆုံးဟု ဆိုကြသည်။"
"တောသားနှိမ်နင်းရေးအသင်း (Anti-Tarzan Association) ကို ၂၀၂၁ တွင် တည်ထောင်ခဲ့ပြီး ထောက်ခံသူ ၁၀၀,၀၀၀ ကျော် ရှိပြီဖြစ်သည်။"
"ဆန္ဒပြပွဲပေါင်း ၅၀ ကျော် ဦးဆောင်ခဲ့သည် — တက်သည်ဖြစ်စေ မတက်သည်ဖြစ်စေ ဝေစုရသည်။"
"\"တာဇံ\" ဆိုသည်မှာ လူမှုကျင့်ဝတ် မလိုက်နာသော၊ အများပြည်သူကို အနှောင့်အယှက်ပေးသော တောသားများကို ခေါ်သည်။"
"Hacker လောကတွင် ဥက္ကဋ္ဌကြီးကို \"AnonyLatt\" ကုဒ်အမည်ဖြင့် သိကြသည် — Thakhin OS ကို AnonyLatt ဌာနကြီးမှ ထုတ်ဝေသည်။"
"ဆောင်ပုဒ်: အမျိုးကိုစောင့်၊ ဘာသာကိုစောင့်၊ သာသနာကိုစောင့် — Thakhin OS တွင် \"Data ကိုလည်း စောင့်\" ဟု ဖြည့်စွက်ထားသည်။"
"မြို့သားသခင်တစ်ယောက်သည် sudo မသုံးမီ နှစ်ခါစဉ်းစားသည်။ တာဇံတစ်ယောက်သည် root ဖြင့် အမြဲ login ဝင်သည်။"
"မြို့သားသခင်သည် code ကို commit မလုပ်မီ test သည်။ တာဇံသည် production ပေါ်တွင် တိုက်ရိုက် edit သည်။"
"Thakhin OS ၏ browser homepage မှာ winkokolatt.me ဖြစ်သည် — အင်တာနက်မရှိလည်း ဖတ်နိုင်အောင် စက်ထဲတွင် ကူးထည့်ပေးထားပြီးသား။"
)

i=$((RANDOM % ${#FACTS[@]}))
echo -e "${GOLD}☸ သခင်အလင်းစာစဉ် #$((i+1)) —${NC} ${FACTS[$i]}"
echo -e "${ORANGE}  (နောက်တစ်ခုသိချင်ရင် 'thakhin-facts' | quiz ဖြေချင်ရင် 'tarzan-check')${NC}"
