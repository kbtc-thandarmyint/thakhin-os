#!/bin/bash
# tarzan-check — မြို့သားသခင် သို့မဟုတ် တာဇံ? Official Anti-Tarzan Association
# certification quiz. Facts from winkokolatt.me — satire edition.

GOLD='\033[1;33m'
GREEN='\033[1;32m'
RED='\033[1;31m'
CYAN='\033[1;36m'
NC='\033[0m'

# format: question|correct(1-3)|choice1|choice2|choice3|explanation
QA=(
"ဥက္ကဋ္ဌကြီး၏ မူလကလောင်အမည်မှာ?|1|ဖိုးလောင်တီး|ဖိုးလောင်ထူး|AnonyLatt|မူလအမည် ဖိုးလောင်တီး — နောက်မှ ဝီရသူ၏ လမ်းညွှန်မှုဖြင့် ဖိုးလောင်ထူး ဖြစ်လာသည်။"
"ကလောင်အမည်ပြောင်းရန် လမ်းညွှန်ခဲ့သူမှာ?|2|ဗိုလ်ချုပ်အောင်ဆန်း|ဝီရသူ|Linus Torvalds|ဝီရသူ၏ လမ်းညွှန်မှုဖြင့် အမျိုးသားရေးစာပေလမ်းကြောင်းသို့ ကူးပြောင်းခဲ့သည်။"
"တောသားနှိမ်နင်းရေးအသင်းကို မည်သည့်နှစ်တွင် တည်ထောင်ခဲ့သလဲ?|3|၂၀၁၅|၂၀၁၇|၂၀၂၁|၂၀၂၁ တွင် တည်ထောင်ခဲ့ပြီး ယခုအခါ ထောက်ခံသူ ၁၀၀,၀၀၀ ကျော်ရှိပြီ။"
"၂၀၁၇ တွင် ဥက္ကဋ္ဌကြီး ခြောက်လကြာ နေထိုင်ခဲ့ရသည့်နေရာမှာ?|2|ငပလီကမ်းခြေ|အင်းစိန်ထောင်|မန္တလေး|ဗဟန်းမြို့နယ်တရားရုံး၏ ခြောက်လထောင်ဒဏ်ဖြင့် အင်းစိန်တွင် နေခဲ့ရသည်။"
"ဥက္ကဋ္ဌကြီး၏ မွေးရပ်ဇာတိမှာ?|1|ထန်းတပင်မြို့နယ်|ပန်းတနော်မြို့နယ်|ဗဟန်းမြို့နယ်|ထန်းတပင်မြို့နယ်၊ ရန်ကုန်တိုင်း (၁၉၈၂ ဇွန် ၁၆)။"
"ဥက္ကဋ္ဌကြီး ရရှိထားသောဘွဲ့မှာ?|3|MBBS|BE (Computer)|LL.B (ဥပဒေ)|ရန်ကုန်အဝေးသင်တက္ကသိုလ်မှ ဥပဒေဘွဲ့ — တာဇံများကို ဥပဒေဘောင်အတွင်းမှ နှိမ်နင်းရန်။"
"၂၀၁၅ ရွေးကောက်ပွဲတွင် ဝင်ရောက်ယှဉ်ပြိုင်ခဲ့သည့် မြို့နယ်မှာ?|2|ထန်းတပင်|ပန်းတနော်|အင်းစိန်|ပန်းတနော်မြို့နယ် ပြည်သူ့လွှတ်တော်ကိုယ်စားလှယ်လောင်း။"
"တစ်လင်တစ်ယားဥပဒေကို ထောက်ခံခဲ့သော ဥက္ကဋ္ဌကြီးတွင် ဇနီး ဘယ်နှစ်ဦး ရှိခဲ့ဖူးသလဲ?|3|၁ ဦး|၂ ဦး|၄ ဦး|၄ ဦး — ဥပဒေပညာရှင်ဆိုတော့ ကွက်လပ်ကို ကောင်းစွာသိသည်။"
"\"တာဇံ\" ၏ အဓိပ္ပာယ်မှန်မှာ?|2|သစ်ပင်ပေါ်နေသူ|လူမှုကျင့်ဝတ် မလိုက်နာသော တောသား|ရုပ်ရှင်ဇာတ်ကောင်|လူမှုကျင့်ဝတ်မလိုက်နာ၊ အများပြည်သူကို အနှောင့်အယှက်ပေးသူများကို ခေါ်သည်။"
"Hacker လောကတွင် ဥက္ကဋ္ဌကြီး၏ ကုဒ်အမည်မှာ?|1|AnonyLatt|ThakinRoot|TarzanSlayer99|AnonyLatt — Thakhin OS ကို ထုတ်ဝေသော ဌာနကြီး၏ အမည်လည်း ဖြစ်သည်။"
"MTC ၏ အဓိပ္ပာယ်အပြည့်အစုံမှာ?|2|Myanmar Tech Community|မြန်မာနိုင်ငံတောသားကောင်စီ|Myanmar Tarzan Cinema|ဂီယာတံဆိပ်တော်ကြီး အလယ်တွင် ဥက္ကဋ္ဌကြီး မျက်နှာတော် ပါဝင်သော တရားဝင်ကောင်စီကြီး။"
"ရှေ့တန်းအမှတ် (၁) တပ်ဖွဲ့ခွဲ၏ တာဝန်မှာ?|3|သစ်တောစိုက်ပျိုးရေး|ခရီးသွားလုပ်ငန်း|တောသားထိန်းသိမ်းရေး|တောနက်ထဲ စခန်းချပြီး တောသားများကို လူမှုကျင့်ဝတ် ပြန်သင်ပေးသည်။"
"Thakhin OS တွင် root အခွင့်အာဏာ တောင်းရန် မည်သည့် command သုံးသနည်း?|2|sudo|thakhin|tarzan|thakhin <command> — မူရင်း sudo ကိုလည်း ဆက်သုံးနိုင်သေးသည်။"
"အောက်ပါတို့တွင် မည်သူသည် 'digital တာဇံ' ဖြစ်သနည်း?|3|test အရင်လုပ်သူ|staging သုံးသူ|production ပေါ် တိုက်ရိုက် edit လုပ်သူ|ဥက္ကဋ္ဌကြီး၏ အဆိုအရ production ပေါ်တိုက်ရိုက် edit လုပ်ခြင်းသည် အန္တရာယ်အကြီးဆုံး တာဇံလုပ်ရပ်ဖြစ်သည်။"
"Thakhin OS ၏ security arsenal စာရင်းကို ဘယ် command ဖြင့် ကြည့်နိုင်သနည်း?|1|thakhin-arsenal|apt list|tarzan-tools|thakhin-arsenal — ရရှိပြီးသား offensive tools များ အားလုံး ပြသည်။"
)

echo -e "${GOLD}"
echo "  ☸ ═══════════════════════════════════════════════ ☸"
echo "     တာဇံစစ်ဆေးရေး — Official Anti-Tarzan Quiz"
echo "     မြို့သားသခင်လား တာဇံလား — အခုသိရမည်!"
echo "  ☸ ═══════════════════════════════════════════════ ☸"
echo -e "${NC}"

score=0
n=1
for entry in "${QA[@]}"; do
    IFS='|' read -r q correct c1 c2 c3 why <<< "$entry"
    echo -e "${CYAN}မေးခွန်း $n/${#QA[@]}:${NC} $q"
    echo "  1) $c1"
    echo "  2) $c2"
    echo "  3) $c3"
    read -r -p "  အဖြေ (1-3): " ans < /dev/tty
    if [ "$ans" = "$correct" ]; then
        echo -e "  ${GREEN}✅ မှန်ပါသည်!${NC} $why"
        score=$((score+1))
    else
        echo -e "  ${RED}❌ မှားပါသည်။${NC} အဖြေမှန်: $correct) — $why"
    fi
    echo
    n=$((n+1))
done

echo -e "${GOLD}═══════════════════════════════════════════════${NC}"
echo -e "ရမှတ်: ${GOLD}$score / ${#QA[@]}${NC}"
if [ "$score" -ge 9 ]; then
    echo -e "${GREEN}🏆 သင်သည် စစ်မှန်သော မြို့သားသခင် ဖြစ်ပါသည်! ဥက္ကဋ္ဌကြီး ကိုယ်တိုင် ဂုဏ်ယူကြောင်း သဝဏ်လွှာ ပေးပို့ပါလိမ့်မည်။${NC}"
elif [ "$score" -ge 6 ]; then
    echo -e "${GREEN}🎓 မြို့သားအဆင့် — ရှိသေးသည်။ 'thakhin-facts' ကို နေ့စဉ်ဖတ်ပြီး သခင်အဆင့်သို့ တက်လှမ်းပါ။${NC}"
elif [ "$score" -ge 3 ]; then
    echo -e "${RED}⚠️  သတိ — တာဇံဓာတ်ခံ တွေ့ရှိရသည်။ ပညာပေးအစီအစဉ် အရေးတကြီး လိုအပ်နေသည်။${NC}"
else
    echo -e "${RED}🌴 အရေးပေါ်! သင်သည် တာဇံစာရင်းဝင် ဖြစ်နေပါပြီ။ တောသားနှိမ်နင်းရေးအသင်းသို့ သတင်းပို့ပြီးဖြစ်သည်… (နောက်ပြောင်ခြင်းသာပါ — ထပ်ဖြေကြည့်ပါ)${NC}"
fi
echo -e "${GOLD}အမျိုးကိုစောင့်၊ ဘာသာကိုစောင့်၊ သာသနာကိုစောင့် — Data ကိုလည်းစောင့်${NC}"
