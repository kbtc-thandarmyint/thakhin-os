#!/bin/sh
# Auto-login the baked 'thakhin' user straight into XFCE. High-priority conf.d
# file (90-) so it overrides anything live-config writes.
set -e

mkdir -p /etc/lightdm/lightdm.conf.d
cat > /etc/lightdm/lightdm.conf.d/90-thakhin-autologin.conf <<EOF
[Seat:*]
autologin-user=thakhin
autologin-user-timeout=0
autologin-session=xfce
user-session=xfce
EOF

echo "Autologin configured for baked user 'thakhin' (session xfce)."
